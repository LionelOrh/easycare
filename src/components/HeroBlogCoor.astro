---
import { Image } from "astro:assets";
import bn1 from "../assets/bc-1.webp";
import bn2 from "../assets/bc-2.webp";
import bn3 from "../assets/bc-3.webp";
import bn4 from "../assets/bc-4.webp";
import bn5 from "../assets/bc-5.webp";
import bn6 from "../assets/bc-6.webp";

const cards = [
	{ title: "Post 1", img: bn1 },
	{ title: "Post 2", img: bn2 },
	{ title: "Post 3", img: bn3 },
	{ title: "Post 4", img: bn4 },
	{ title: "Post 5", img: bn5 },
	{ title: "Post 6", img: bn6 },
];
---

<section id="hero-blog-coor" class="hero-blog-coor">
	<div class="hero-blog-coor__container">
		<h1 class="hero-blog-coor__title">Blogs</h1>

		<div class="hero-blog-coor__track-wrap">
			<div class="hero-blog-coor__track">
				{
					[...cards, ...cards].map((card) => (
						<article class="hero-blog-coor__card" aria-label={card.title}>
							<Image src={card.img} alt={card.title} class="hero-blog-coor__image" />
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.hero-blog-coor {
		background-color: #f4efe6;
		padding: 130px 0 56px;
		overflow: hidden;
	}

	.hero-blog-coor__container {
		margin: 0 auto;
		padding: 0 28px;
	}

	.hero-blog-coor__title {
		margin: 0 0 22px;
		font-family: "Playfair Display", serif;
		font-size: 52px;
		line-height: 1.02;
		color: #2f2f2f;
		text-align: center;
	}

	.hero-blog-coor__track-wrap {
		overflow: hidden;
		border: 1px solid #e2d7c8;
		background-color: #fbf8f2;
		border-radius: 8px;
		padding: 16px 0;
	}

	.hero-blog-coor__track {
		display: flex;
		gap: 30px;
		width: max-content;
		padding: 0 16px;
		animation: slideBlog 50s linear infinite;
	}

	.hero-blog-coor__card {
		flex: 0 0 340px;
		height: 35dvh;
		border-radius: 6px;
		overflow: hidden;
	}

	.hero-blog-coor__image {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.hero-blog-coor__track-wrap:hover .hero-blog-coor__track {
		animation-play-state: paused;
	}

	@keyframes slideBlog {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(calc((-540px - 16px) * 6));
		}
	}

	@media (max-width: 900px) {
		.hero-blog-coor {
			padding: 110px 0 40px;
		}

		.hero-blog-coor__container {
			padding: 0 16px;
		}

		.hero-blog-coor__title {
			font-size: 42px;
			margin-bottom: 16px;
		}

		.hero-blog-coor__track {
			gap: 12px;
			padding: 0 12px;
		}

		.hero-blog-coor__card {
			flex-basis: 280px;
			height: 190px;
		}

		@keyframes slideBlog {
			0% {
				transform: translateX(0);
			}
			100% {
				transform: translateX(calc((-280px - 12px) * 6));
			}
		}
	}

	@media (max-width: 560px) {
		.hero-blog-coor__title {
			font-size: 34px;
		}

		.hero-blog-coor__card {
			flex-basis: 220px;
			height: 150px;
		}

		@keyframes slideBlog {
			0% {
				transform: translateX(0);
			}
			100% {
				transform: translateX(calc((-220px - 12px) * 6));
			}
		}
	}
</style>
