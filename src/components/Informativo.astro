---
import { Image } from "astro:assets";
import info1 from "../assets/i-1.webp";
import info2 from "../assets/i-2.webp";
---

<section id="informativo" class="informativo">
    <div class="informativo-container">
        <div class="info-grid">
            <div class="info-top-left">
                <h2 class="i_grid_text">Eleva tu</h2>
                <div class="i_dots"></div>
            </div>
            <div class="info-top-right">
                <div class="i_image_contain">
                    <Image
                        src={info1}
                        alt="Banner Informativo"
                        class="i_grid_image"
                    />
                    <Image
                        src={info2}
                        alt="Banner Informativo"
                        class="i_grid_image"
                    />
                </div>
                <div class="i_text_contain_more">
                    <a href="/productos" class="i_grid_text_more"
                        >Más <span class="i_arrow" aria-hidden="true">></span
                        ></a
                    >
                </div>
            </div>
            <div class="info-bottom-left">
                <p class="i_grid_text_min">
                    Rutina de cuidado de la piel con productos inspirados en el
                    cuidado coreano, asesoramiento cercano y calidad que se
                    siente y se ve.
                </p>
            </div>
            <div class="info-bottom-right">
                <h2 class="i_grid_text">Experiencia de SkinCare</h2>
                <div class="i_dots"></div>
            </div>
        </div>
    </div>
</section>
<style>
    /* Estilos Base (Desktop) */
    .informativo {
        padding: 15dvh 0px;
        background-color: #f9f9f9;
        overflow: hidden;
    }

    .informativo-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 28px; /* Coherencia con productos */
    }

    .informativo h2 {
        font-size: 68px;
        color: #333;
        margin: 0;
        line-height: 1.05;
        font-family: poppins, sans-serif;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        grid-template-rows: auto auto;
        column-gap: 34px;
        row-gap: 14px;
        align-items: center;
    }

    .info-top-left {
        grid-column: 1;
        grid-row: 1;
        text-align: left;
    }
    .info-top-right {
        grid-column: 2;
        grid-row: 1;
        display: flex;
        align-items: center;
        justify-content: space-around;
        border-top: 1px solid #d7d0c4;
        border-bottom: 1px solid #d7d0c4;
        padding: 10px 0;
    }

    .info-bottom-left {
        grid-column: 1;
        grid-row: 2;
    }
    .info-bottom-right {
        grid-column: 2;
        grid-row: 2;
        text-align: left;
    }

    .i_image_contain {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .i_grid_image {
        width: 225px;
        height: auto;
        border-radius: 10px;
        object-fit: cover;
    }
    .i_grid_text {
        font-size: 68px;
        color: #333;
        margin: 0;
        line-height: 1.05;
        font-family: poppins, sans-serif;
    }
    .i_dots {
        width: 100%;
        height: 20px;
        margin-top: 5px;
        position: relative;
        overflow: hidden;
    }
    .i_dots::after {
        /* Generamos una fila larga de puntos reales */
        content: "....................................................................................................";
        position: absolute;
        top: 0;
        left: 0;
        font-size: 30px; /* Tamaño de los puntos */
        letter-spacing: 8px; /* Espacio entre puntos */
        color: #333;
        line-height: 0.5;
    }

    .i_grid_text_more {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 25px;
        color: #555;
        font-family: poppins, sans-serif;
        font-weight: 600;
        text-decoration: none;
    }

    .i_grid_text_min {
        font-size: 15px;
        color: #000;
        line-height: 1.45;
        max-width: 260px;
        font-family: poppins, sans-serif;
    }

    /* --- RESPONSIVE --- */

    @media (max-width: 960px) {
        .informativo h2 {
            font-size: 48px; /* Reducción de título */
        }

        .info-grid {
            grid-template-columns: 200px 1fr; /* Grid más apretado */
            column-gap: 20px;
        }

        .i_grid_image {
            width: 150px; /* Imágenes más pequeñas */
        }
        .i_grid_text { font-size: 48px; }
        .info-grid { grid-template-columns: 1fr 1fr; }
        .i_grid_image { width: 140px; }
    }

    @media (max-width: 640px) {
        .informativo {
            padding: 40px 0; /* Padding igual a productos */
        }

        .informativo-container {
            padding: 0 16px;
        }

        .info-grid {
            display: flex; /* Cambiamos a flex para apilar fácilmente */
            flex-direction: column;
            gap: 24px;
            text-align: center;
        }

        /* Forzamos a que todos los elementos ocupen el ancho total */
        .info-top-left,
        .info-top-right,
        .info-bottom-left,
        .info-bottom-right {
            width: 100%;
            text-align: center;
        }

        .informativo h2 {
            font-size: 31px; /* Igual que el h2 de productos */
        }

        .info-top-right {
            flex-direction: column; /* Apilamos imágenes y link "Más" */
            gap: 20px;
            padding: 20px 0;
        }

        .i_image_contain {
            justify-content: center;
            width: 100%;
        }

        .i_grid_image {
            width: 45%; /* Dos imágenes lado a lado en móvil */
            max-width: 160px;
        }

        .i_grid_text_min {
            max-width: 100%; /* El párrafo ocupa todo el ancho */
            font-size: 15px;
        }

        .i_text_contain_more {
            justify-content: center;
            align-items: center;
        }
        .i_grid_text {
            font-size: 34px; /* Un poco más grande para que resalte en móvil */
            text-align: center;
        }

        .i_dots::after {
            font-size: 30px;
            letter-spacing: 6px;
        }
    }
</style>
