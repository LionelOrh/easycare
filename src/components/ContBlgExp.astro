import FlechaIcon from "../assets/sgv/flecha.astro";
---

<section id="cont-blog-coor" class="cont-blog-coor">
	<div class="cont-blog-coor__container">
		<div class="cont-blog-coor__head">
			<h2>Contenido del Blog para Expertos</h2>
			<p>12 articulos sobre skincare coreano, ingredientes y rutinas reales para cada tipo de piel.</p>
		</div>

		<div class="cont-blog-coor__grid">
			{
				posts.map((post) => (
					<article class="blog-card">
						<Image src={post.img} alt={post.titulo} class="blog-card__img" />
						<div class="blog-card__body">
							<p class="blog-card__cat">{post.categoria}</p>
							<h3 class="blog-card__title">{post.titulo}</h3>
							<p class="blog-card__desc">{post.descripcion}</p>
							<a href="#" class="blog-card__link">
								<span>Leer mas</span>
								<FlechaIcon class="blog-card__link-icon" />
							</a>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.cont-blog-coor {
		background-color: #f8c8dc4b;
		padding: 56px 0 70px;
	}

	.cont-blog-coor__container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 28px;
	}

	.cont-blog-coor__head {
		margin-bottom: 24px;
	}

	.cont-blog-coor__head h2 {
		margin: 0;
		font-family: "Playfair Display", serif;
		font-size: 44px;
		line-height: 1.05;
		color: #2f2f2f;
	}

	.cont-blog-coor__head p {
		margin: 10px 0 0;
		font-family: "Open Sans", sans-serif;
		font-size: 16px;
		line-height: 1.4;
		color: #6f6f6f;
	}

	.cont-blog-coor__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.blog-card {
		background-color: #ffffff;
		border: 1px solid #e6ddd1;
		border-radius: 10px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	.blog-card__img {
		height: 190px;
		width: 100%;
		display: block;
		object-fit: cover;
	}

	.blog-card__body {
		padding: 14px;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.blog-card__cat {
		margin: 0;
		font-family: "Open Sans", sans-serif;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #4f7c68;
	}

	.blog-card__title {
		margin: 0;
		font-family: "Playfair Display", serif;
		font-size: 24px;
		line-height: 1.15;
		color: #2f2f2f;
	}

	.blog-card__desc {
		margin: 0;
		font-family: "Open Sans", sans-serif;
		font-size: 14px;
		line-height: 1.5;
		color: #6f6f6f;
	}

	.blog-card__link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin-top: auto;
		font-family: "Open Sans", sans-serif;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		text-decoration: none;
		color: #b44f68;
	}

	.blog-card__link:hover {
		color: #9c3f56;
	}

	.blog-card__link-icon {
		width: 14px;
		height: 14px;
		display: inline-block;
	}

	@media (max-width: 1024px) {
		.cont-blog-coor__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.cont-blog-coor__head h2 {
			font-size: 38px;
		}
	}

	@media (max-width: 640px) {
		.cont-blog-coor {
			padding: 40px 0 52px;
		}

		.cont-blog-coor__container {
			padding: 0 16px;
		}

		.cont-blog-coor__grid {
			grid-template-columns: 1fr;
		}

		.cont-blog-coor__head h2 {
			font-size: 31px;
		}

		.blog-card__img {
			height: 176px;
		}
	}
</style>
