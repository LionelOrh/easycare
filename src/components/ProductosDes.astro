---
import { Image } from "astro:assets";
import producto1 from "../assets/i-3.webp";
import producto2 from "../assets/i-4.webp";
import producto3 from "../assets/i-5.webp";
---

<section id="productos-destacados" class="productos-destacados">
	<div class="productos-container">
		<div class="productos-head">
			<h2>3 Productos Destacados</h2>
			<p>Seleccion coreana para limpiar, hidratar y proteger tu piel.</p>
		</div>

		<div class="productos-grid">
			<article class="producto-card">
				<div class="producto-img">
					<Image src={producto1} alt="Limpiador Centella" class="producto-img-real" />
				</div>
				<div class="producto-info">
					<h3>Limpiador Centella</h3>
					<p>Limpieza suave para retirar impurezas sin resecar.</p>
					<span>EUR 24.90</span>
				</div>
			</article>

			<article class="producto-card">
				<div class="producto-img">
					<Image src={producto2} alt="Serum Vitamina C" class="producto-img-real" />
				</div>
				<div class="producto-info">
					<h3>Serum Vitamina C</h3>
					<p>Ilumina el tono y mejora la textura de la piel.</p>
					<span>EUR 34.50</span>
				</div>
			</article>

			<article class="producto-card">
				<div class="producto-img">
					<Image src={producto3} alt="Crema Barrier Care" class="producto-img-real" />
				</div>
				<div class="producto-info">
					<h3>Crema Barrier Care</h3>
					<p>Hidratacion profunda con acabado ligero y comodo.</p>
					<span>EUR 29.00</span>
				</div>
			</article>
		</div>
	</div>
</section>

<style>
	.productos-destacados {
		background: linear-gradient(180deg, #dff2e8 0%, #eaf7f1 45%, #f4f8f6 100%);
		padding: 56px 0;
	}

	.productos-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 28px;
	}

	.productos-head {
		margin-bottom: 24px;
	}

	.productos-head h2 {
		margin: 0;
		color: #333333;
		font-family: "Playfair Display", serif;
		font-size: 46px;
		line-height: 1.05;
	}

	.productos-head p {
		margin: 10px 0 0;
		color: #6f6f6f;
		font-family: "Open Sans", sans-serif;
		font-size: 17px;
		line-height: 1.4;
	}

	.productos-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.producto-card {
		background-color: #fffaf2;
		border: 1px solid #d8e7dd;
		border-radius: 10px;
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}

	.producto-card:hover {
		transform: translateY(-4px);
		border-color: #b9d8c8;
		box-shadow: 0 12px 22px rgba(103, 128, 114, 0.16);
	}

	.producto-img {
		height: 380px;
		width: 100%;
	}

	.producto-img-real {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.producto-info {
		padding: 14px 14px 16px;
	}

	.producto-info h3 {
		margin: 0;
		color: #333333;
		font-family: "Playfair Display", serif;
		font-size: 24px;
		line-height: 1.1;
	}

	.producto-info p {
		margin: 8px 0 0;
		color: #6f6f6f;
		font-family: "Open Sans", sans-serif;
		font-size: 15px;
		line-height: 1.45;
	}

	.producto-info span {
		display: inline-block;
		margin-top: 10px;
		color: #4f7c68;
		font-family: "Open Sans", sans-serif;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
	}

	@media (max-width: 960px) {
		.productos-head h2 {
			font-size: 38px;
		}

		.productos-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	} 

	@media (max-width: 640px) {
		.productos-destacados {
			padding: 40px 0;
		}

		.productos-container {
			padding: 0 16px;
		}

		.productos-head h2 {
			font-size: 31px;
		}

		.productos-head p {
			font-size: 15px;
		}

		.productos-grid {
			grid-template-columns: 1fr;
		}

		.producto-img {
			height: 210px;
		}
	}
</style>
