---

<section id="catalogo-productos" class="catalogo-productos">
    <div class="catalogo-productos__container">
        <div class="catalogo-productos__head">
            <div>
                <h2>Catálogo de Productos</h2>
                <p>
                    Encuentra el cuidado ideal para tu piel con productos
                    coreanos seleccionados por calidad, innovación y eficacia.
                </p>
            </div>

            <div
                class="catalogo-productos__filters"
                aria-label="Filtros simples"
            >
                {
                    filters.map((filter) => (
                        <span class="catalogo-productos__filter">{filter}</span>
                    ))
                }
            </div>
        </div>

        <div class="catalogo-productos__sections">
            {
                sections.map((section) => (
                    <section class="catalogo-productos__section">
                        <h3 class="catalogo-productos__section-title">
                            {section.title}
                        </h3>
                        <div class="catalogo-productos__grid">
                            {section.items.map((product) => (
                                <article class="product-card">
                                    <Image
                                        src={product.image}
                                        alt={product.title}
                                        class="product-card__image"
                                    />
                                    <div class="product-card__body">
                                        <div class="product-card__top">
                                            <p class="product-card__category">
                                                {section.title}
                                            </p>
                                            <p class="product-card__price">
                                                {product.price}
                                            </p>
                                        </div>
                                        <h4 class="product-card__title">
                                            {product.title}
                                        </h4>
                                        <p class="product-card__desc">
                                            {product.description}
                                        </p>
                                        <div class="product-card__meta">
                                            <p>
                                                <strong>Beneficios:</strong>
                                            </p>
                                            <ul class="product-card__benefits-list">
                                                {product.benefits.map(
                                                    (item) => (
                                                        <li>{item}</li>
                                                    ),
                                                )}
                                            </ul>
                                        </div>
                                        <p class="product-card__meta">
                                            <strong>Tipo de piel:</strong>{" "}
                                            {product.skin}
                                        </p>
                                        <div class="add-car">
                                            <a href="">
                                                <BolsaIcon class="add-car__icon" />
                                                <span>Al carrito</span>
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            ))}
                        </div>
                    </section>
                ))
            }
        </div>
    </div>
</section>

<style>
    .catalogo-productos {
        background: linear-gradient(180deg, #fff6e9 0%, #f6f1e8 100%);
        padding: 150px 0 72px;
        font-family: "Poppins", sans-serif;
    }

    .catalogo-productos__container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 28px;
    }

    .catalogo-productos__head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 26px;
    }

    .catalogo-productos__head h2 {
        margin: 0;
        font-family: "Poppins", sans-serif;
        font-size: clamp(2.1rem, 4vw, 3rem);
        line-height: 1.08;
        font-weight: 800;
        letter-spacing: -0.015em;
        color: #2b2f32;
    }

    .catalogo-productos__head p {
        margin: 10px 0 0;
        max-width: 700px;
        font-family: "Poppins", sans-serif;
        font-size: 18px;
        line-height: 1.6;
        font-weight: 400;
        color: #5f666b;
    }

    .catalogo-productos__filters {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 10px;
    }

    .catalogo-productos__filter {
        display: inline-flex;
        align-items: center;
        padding: 9px 14px;
        border-radius: 999px;
        background-color: #ffffff;
        border: 1px solid #d8e7dd;
        font-family: "Poppins", sans-serif;
        font-size: 13px;
        font-weight: 600;
        color: #3b6f64;
    }

    .catalogo-productos__sections {
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    .catalogo-productos__section {
        padding: 18px 0 0;
        border-top: 1px solid rgba(79, 124, 104, 0.18);
    }

    .catalogo-productos__section-title {
        margin: 0 0 16px;
        font-family: "Poppins", sans-serif;
        font-size: 28px;
        line-height: 1.15;
        font-weight: 700;
        letter-spacing: -0.008em;
        color: #2c3034;
    }

    .catalogo-productos__grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .product-card {
        background-color: #ffffff;
        border: 1px solid #e6ddd1;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(45, 52, 54, 0.06);
        display: flex;
        flex-direction: column;
    }

    .product-card__image {
        height: 390px;
        width: 100%;
        background-color: #c84f4f;
        border-bottom: 2px solid #d6d6d6;
    }

    .product-card__body {
        padding: 14px 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .product-card__top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
    }

    .product-card__category {
        margin: 0;
        font-family: "Poppins", sans-serif;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #3b6f64;
    }

    .product-card__price {
        margin: 0;
        font-family: "Poppins", sans-serif;
        font-size: 16px;
        font-weight: 800;
        color: #a04a61;
        white-space: nowrap;
    }

    .product-card__title {
        margin: 0;
        font-family: "Poppins", sans-serif;
        font-size: 20px;
        line-height: 1.2;
        font-weight: 700;
        color: #2d3338;
    }

    .product-card__desc {
        margin: 0;
        font-family: "Poppins", sans-serif;
        font-size: 14px;
        line-height: 1.6;
        font-weight: 400;
        color: #5e656a;
    }

    .product-card__meta {
        margin: 0;
        font-family: "Poppins", sans-serif;
        font-size: 13px;
        line-height: 1.55;
        color: #485057;
    }

    .product-card__meta p {
        margin: 0;
    }

    .product-card__benefits-list {
        margin: 4px 0 0;
        padding-left: 18px;
    }

    .product-card__benefits-list li {
        margin: 0;
    }

    .product-card__meta strong {
        color: #2f2f2f;
    }
    .add-car {
        background-color: #a4af98;
        padding: 8px 12px;
        border-radius: 30px;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 10px;
    }
    .add-car a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: #ffffff;
        font-family: "Open Sans", sans-serif;
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .add-car__icon {
        width: 16px;
        height: 16px;
        display: inline-block;
    }

    @media (max-width: 1024px) {
        .catalogo-productos__head {
            flex-direction: column;
            align-items: flex-start;
        }

        .catalogo-productos__filters {
            justify-content: flex-start;
        }

        .catalogo-productos__grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .catalogo-productos__section-title {
            font-size: 24px;
        }

        .catalogo-productos__head h2 {
            font-size: 38px;
        }
    }

    @media (max-width: 640px) {
        .catalogo-productos {
            padding: 40px 0 56px;
        }

        .catalogo-productos__container {
            padding: 0 16px;
        }

        .catalogo-productos__grid {
            grid-template-columns: 1fr;
        }

        .catalogo-productos__section {
            padding-top: 14px;
        }

        .catalogo-productos__head h2 {
            font-size: 31px;
        }

        .catalogo-productos__head p {
            font-size: 15px;
        }

        .product-card__image {
            height: 176px;
        }
    }
</style>
